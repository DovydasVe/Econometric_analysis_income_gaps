gen big_hhwt = big_city * hhwt
reg log_inctot degree age i.sex cit_1 cit_2 yrsusa1 big_city i.empstat asian amind black pacis white other immyear natyear hhwt i.marst big_hhwt
gen immi_hhwt = cit_3 * big_city
summarize cit_2, detail
sum(cit_2)
describe cit_2
tabulate citizen
